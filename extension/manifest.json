{
  "manifest_version": 3,
  "name": "Web Annotator for Pi",
  "version": "1.6.1",
  "description": "Annotate webpage elements or text, send targeted change requests to Pi, or copy them as Markdown.",
  "incognito": "not_allowed",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_title": "Toggle Web Annotator for Pi - Alt+Shift+A"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+A"
      },
      "description": "Toggle annotations on/off on this page"
    },
    "copy-annotations": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Copy all annotations as markdown"
    },
    "copy-annotations-json": {
      "suggested_key": {
        "default": "Alt+Shift+J"
      },
      "description": "Copy all annotations as JSON"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pi-web-annotator@pbjorklund.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": [
          "browsingActivity",
          "websiteContent"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
